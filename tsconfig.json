{
	"compilerOptions": {
        "types": ["node", "bundlebd"],
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@activity_feed/*": ["src/activity_feed/*"],
            "@application_news/*": ["src/activity_feed/components/application_news/*"],
            "@coachmark/*": ["src/activity_feed/components/coachmark/*"],
            "@common/*": ["src/activity_feed/common/*"],
            "@now_playing/*": ["src/activity_feed/components/now_playing/*"],
            "@quick_launcher/*": ["src/activity_feed/components/quick_launcher/*"],
            "@modules/*": ["src/modules/*"],
            "@settings/*": ["src/settings/*"]
        }
	}
}